{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_SUPPORT_URL": "https://robom.kr/support",
        "EXPO_PUBLIC_PRIVACY_URL": "https://robom.kr/privacy/outbom"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
